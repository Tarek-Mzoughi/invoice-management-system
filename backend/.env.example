NODE_ENV=development
APP_PORT=3000
APP_NAME="Invoice System API Server" 
API_PREFIX=api
APP_LANGUAGE=en

TZ=UTC+1

DATABASE_TYPE=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=root
DATABASE_PASSWORD=password
DATABASE_NAME=invoicing
DATABASE_SYNCHRONIZE=false
DATABASE_DROP_SCHEMA=false
DATABASE_SSL_ENABLED=false
DATABASE_LOGGING=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=

HTTP_ENABLE=true

JWT_SECRET=JWTSecret@!
JWT_REFRESH_TOKEN_SECRET=JWTRefreshTokenSecret@!
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

WEB_APP_URL=http://localhost:3001

PASSWORD_RESET_EXPIRATION_MINUTES=15
EMAIL_VERIFICATION_EXPIRATION_MINUTES=30

SMTP_HOST=smtp-host
SMTP_PORT=smtp-port
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass

STORAGE_DRIVER=local # can be local or s3

S3_BUCKET=invoicing
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123

UPLOAD_PATH=/home/cardinal/Documents/upload

# AI Module
AI_ENABLED=true
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
