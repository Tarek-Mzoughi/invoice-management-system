NODE_ENV=development
APP_PORT=8082
APP_HOST=localhost
APP_NAME="Invoice Management API Server"
API_PREFIX=api
APP_LANGUAGE=en

TZ=Africa/Tunis

DATABASE_TYPE=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=invoicing_user
DATABASE_PASSWORD=invoicing_password
DATABASE_NAME=invoicing
DATABASE_SYNCHRONIZE=false
DATABASE_DROP_SCHEMA=false
DATABASE_SSL_ENABLED=false
DATABASE_LOGGING=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=

HTTP_ENABLE=true

JWT_SECRET=replace-with-a-secure-access-token-secret
JWT_REFRESH_TOKEN_SECRET=replace-with-a-secure-refresh-token-secret
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

WEB_APP_URL=http://localhost:3000

PASSWORD_RESET_EXPIRATION_MINUTES=15
EMAIL_VERIFICATION_EXPIRATION_MINUTES=30

SMTP_HOST=smtp-host
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass

STORAGE_DRIVER=local

S3_BUCKET=invoicing
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123

UPLOAD_PATH=./uploads

# AI Module
AI_ENABLED=false
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
